---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECTS } from '../data/projects';
import Tag from '../components/Tag.astro';

const categories = ['Research engineering', 'Product / full-stack'] as const;
---
<BaseLayout title="Projects" description="Research software and full-stack projects by James Belanger.">
  <h1 class="text-3xl font-bold tracking-tight">Projects</h1>
  <p class="mt-3 max-w-2xl text-lg leading-relaxed text-muted">
    Reproducible scientific software, and a couple of shipped full-stack apps — the engineering behind the research.
  </p>

  {
    categories.map((cat) => (
      <section class="mt-10">
        <h2 class="text-lg font-semibold text-muted">{cat}</h2>
        <div class="mt-3 grid gap-4 sm:grid-cols-2">
          {PROJECTS.filter((p) => p.category === cat).map((p) => (
            <article class="flex flex-col rounded-lg border border-line bg-card p-5">
              <h3 class="text-base font-semibold leading-snug">{p.name}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{p.blurb}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {p.stack.map((s) => (
                  <Tag label={s} />
                ))}
              </div>
              {p.links && (
                <div class="mt-3 flex flex-wrap gap-x-4 text-sm">
                  {p.links.map((l) => (
                    <a href={l.href}>{l.label} →</a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  }
</BaseLayout>
