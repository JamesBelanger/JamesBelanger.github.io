---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';

const skills: { group: string; items: string }[] = [
  { group: 'Programming', items: 'Python, MATLAB, R, Bash' },
  { group: 'ML / DL', items: 'PyTorch, scikit-learn, HuggingFace transformers, sentence-transformers' },
  {
    group: 'Methods',
    items:
      'Poisson & Gaussian GLM/GAM, cross-validated ridge, RSA, Procrustes, SVM, PCA / manifold analysis, GCN, wavelets',
  },
  {
    group: 'Neural data',
    items:
      'Single-unit spike-train analysis, LFP/iEEG preprocessing, PSTH, spike-sorting QA (UMAP), population geometry',
  },
  { group: 'NLP', items: 'spaCy, NLTK, pyphen, GPT-2 surprisal, SBERT' },
  { group: 'Web / tools', items: 'React + Vite, Leaflet, Supabase, Tailwind, Git, conda, Docker, Obsidian' },
];
---
<BaseLayout title="CV" description="Curriculum vitae of James Belanger.">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-bold tracking-tight">Curriculum Vitae</h1>
    {SITE.links.cv && (
      <a
        href={SITE.links.cv}
        class="rounded-md bg-accent px-3.5 py-1.5 text-sm font-medium text-white no-underline hover:no-underline hover:opacity-90"
      >
        Download PDF
      </a>
    )}
  </div>

  <!-- Education -->
  <section class="mt-10">
    <h2 class="text-lg font-semibold text-muted">Education</h2>
    <div class="mt-3">
      <h3 class="font-semibold">Rice University</h3>
      <p class="text-sm text-muted">
        B.A. in Linguistics and Psychology · Minors in Spanish and Neuroscience · May 2025
      </p>
      <p class="mt-1 text-sm text-muted">GPA 3.94 / 4.0 · Cum Laude · Rice Undergraduate Scholars Program (RUSP).</p>
      <p class="mt-2 text-sm text-muted">
        Honors thesis: <em>Encoding of Grammatical Roles in Hippocampus and Anterior Cingulate Cortex at
        the Single-Neuron Level</em> · advisor: Prof. Suzanne Kemmer.
      </p>
    </div>
  </section>

  <!-- Research experience -->
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-muted">Research experience</h2>
    <div class="mt-3">
      <h3 class="font-semibold">Hayden Lab — Baylor College of Medicine</h3>
      <p class="text-sm text-muted">{SITE.role} · May 2024 – present</p>
      <ul class="mt-2 list-disc space-y-1.5 pl-5 text-sm leading-relaxed">
        <li>
          Built a cross-validated ridge / Poisson encoding pipeline for hippocampal single-unit spiking
          (435 neurons, 7,346 word-level timepoints) during naturalistic listening.
        </li>
        <li>
          Engineered a 9-layer linguistic feature extractor (57 scalar features: phonology, morphology,
          syntax, discourse) and adversarially purified GCN syntactic + SBERT semantic embeddings for clean
          dissociation of linguistic levels.
        </li>
        <li>
          Key result: an exhaustive scalar baseline predicts hippocampal firing (mean r = 0.334, 399/435
          neurons significant); embeddings add Δr = +0.021 unique variance.
        </li>
        <li>Mentor three undergraduate researchers in statistical neuroscience and Python/MATLAB.</li>
      </ul>
    </div>

    <div class="mt-6">
      <h3 class="font-semibold">Martin Lab of Language &amp; Memory — Rice University</h3>
      <p class="text-sm text-muted">Research assistant · Sep 2022 – May 2025</p>
      <ul class="mt-2 list-disc space-y-1.5 pl-5 text-sm leading-relaxed">
        <li>
          Analyzed phonological and semantic working-memory data across 1,000+ participants with multiple
          regression, factor analysis, and PCA.
        </li>
        <li>Built OpenAI Whisper pipelines to transcribe and quantify language production in aphasic patients.</li>
      </ul>
    </div>

    <div class="mt-6">
      <h3 class="font-semibold">Language &amp; Cognitive Development Lab — UC Berkeley</h3>
      <p class="text-sm text-muted">Summer research assistant · Jun – Aug 2023</p>
      <ul class="mt-2 list-disc space-y-1.5 pl-5 text-sm leading-relaxed">
        <li>Studied social-cue and priming effects on semantically ambiguous nouns in 50+ children (analyses in R).</li>
        <li>Built a Vosk + Whisper pipeline producing time-stamped transcripts from 150+ hours of audio.</li>
      </ul>
    </div>
  </section>

  <!-- Teaching -->
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-muted">Teaching</h2>
    <div class="mt-3">
      <h3 class="font-semibold">Teaching Assistant — “Words in English”</h3>
      <p class="text-sm text-muted">Prof. Suzanne Kemmer · Rice University</p>
    </div>
  </section>

  <!-- Skills -->
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-muted">Skills</h2>
    <dl class="mt-3 space-y-2 text-sm">
      {
        skills.map((s) => (
          <div class="sm:flex sm:gap-3">
            <dt class="font-medium sm:w-32 sm:shrink-0">{s.group}</dt>
            <dd class="text-muted">{s.items}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Publications -->
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-muted">Publications</h2>
    <p class="mt-2 text-sm text-muted">
      4 peer-reviewed articles (Nature, Nature Neuroscience, Nature Human Behaviour, Cell) and 5 preprints.
      <a href="/publications">See the full list →</a>
    </p>
  </section>

  <!-- Honors & awards -->
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-muted">Honors &amp; awards</h2>
    <ul class="mt-3 list-disc space-y-1.5 pl-5 text-sm leading-relaxed">
      <li>Psi Chi Undergraduate Scholarship (psychology) — $3,000, 2024</li>
      <li>Rice Undergraduate Scholars Program Scholarship — $1,000, 2024</li>
      <li>Owl Edge Summer Experience Fund — $5,000, 2023</li>
      <li>STaRT@Rice Research Scholarship — 2023</li>
      <li>Omega Psi Cognitive Science Honors Society — 2024</li>
      <li>Award of Excellence in Poster Presentation, Summer Undergraduate Research Symposium — 2022</li>
    </ul>
  </section>

  <p class="mt-10 text-sm text-muted">References available upon request.</p>
</BaseLayout>
