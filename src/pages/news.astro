---
import BaseLayout from '../layouts/BaseLayout.astro';
import { NEWS } from '../data/news';
---
<BaseLayout title="News" description="Recent updates from James Belanger.">
  <h1 class="text-3xl font-bold tracking-tight">News</h1>
  <ul class="mt-8 space-y-5">
    {
      NEWS.map((n) => (
        <li class="flex gap-4">
          <time class="w-16 shrink-0 pt-0.5 font-mono text-sm text-muted">{n.date}</time>
          <p class="leading-relaxed">
            {n.href ? <a href={n.href} class="no-underline hover:underline">{n.text}</a> : n.text}
          </p>
        </li>
      ))
    }
  </ul>
</BaseLayout>
